{
  "name": "@iambilotta/lievit-ui",
  "version": "0.1.0",
  "description": "lievit-ui: a copy-in component registry of owned-source Lit primitives and design tokens (shadcn model). Not a runtime dependency; the source the `lievit add` CLI copies from.",
  "license": "Apache-2.0",
  "author": "Francesco Bilotta",
  "type": "module",
  "private": true,
  "bin": {
    "lievit-add": "./cli/lievit-add.ts"
  },
  "scripts": {
    "build:registry": "tsx cli/build-registry.ts",
    "check:registry": "tsx cli/build-registry.ts --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "happy-dom": "^20.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
