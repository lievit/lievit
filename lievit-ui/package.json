{
  "name": "@lievit/lievit-ui",
  "version": "0.1.0",
  "description": "lievit-ui: a copy-in component registry of owned-source server-rendered JTE primitives + a dependency-free TypeScript client runtime + design tokens (shadcn model). Not a runtime dependency; the source the `lievit add` CLI copies from.",
  "license": "Apache-2.0",
  "author": "Francesco Bilotta",
  "type": "module",
  "private": true,
  "bin": {
    "lievit-add": "./cli/lievit-add.ts"
  },
  "scripts": {
    "build": "tsx cli/build-islands.ts",
    "build:registry": "tsx cli/build-registry.ts",
    "check:registry": "tsx cli/build-registry.ts --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:jte-compile": "bash test/jte-compile/run.sh"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@hotwired/stimulus": "^3.2.2"
  },
  "optionalDependencies": {
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.8",
    "@tiptap/core": "^2.11.7",
    "@tiptap/starter-kit": "^2.11.7",
    "codemirror": "^6.0.2",
    "dompurify": "^3.2.6",
    "marked": "^15.0.12"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.25.6",
    "happy-dom": "^20.10.5",
    "lucide-static": "^1.21.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
