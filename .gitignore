# --- Java / Maven ---
target/
*.class
*.jar
*.war
build/
out/
# maven-shade-plugin artifacts
**/dependency-reduced-pom.xml
# flatten-maven-plugin output (CI-friendly ${revision} resolution; regenerated each build)
**/.flattened-pom.xml
hs_err_pid*
replay_pid*
# JTE precompiled template output (regenerated by the build)
jte-classes/
# jqwik shrinking database (per-run, machine-local)
.jqwik-database

# --- GraalVM native ---
*.so
*.dylib
*.dll
# native-image build dir
**/native/
*.nativetest

# --- Node / Vite (client bundle: htmx + Lit glue) ---
node_modules/
dist/
.vite/
*.tsbuildinfo
bun.lockb
.bun/

# --- IDE ---
.idea/
*.iml
.vscode/
.classpath
.project
.settings/
*.iws

# --- OS / misc ---
.DS_Store
*.log

# --- Local secrets / env (never commit) ---
.env
.env.local
.envrc.local
