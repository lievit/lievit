<?xml version="1.0" encoding="UTF-8"?>
<!--
    Minimal Maven Build Cache config: local-only, SHA-256 hashing of standard inputs.
    No remote cache. Keeps last 3 cached builds per module in ~/.m2/build-cache/.
    Template source: https://maven.apache.org/extensions/maven-build-cache-extension/
    Schema:          https://maven.apache.org/xsd/build-cache-config-1.3.0.xsd
-->
<cache xmlns="http://maven.apache.org/BUILD-CACHE-CONFIG/1.3.0"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://maven.apache.org/BUILD-CACHE-CONFIG/1.3.0 https://maven.apache.org/xsd/build-cache-config-1.3.0.xsd">

    <configuration>
        <enabled>true</enabled>
        <!-- SHA-256: stronger integrity than the default XX algorithm; suitable for a
             published library where reproducibility matters. -->
        <hashAlgorithm>SHA-256</hashAlgorithm>
        <validateXml>true</validateXml>
        <!-- No <remote> block = local cache only. -->
        <local>
            <maxBuildsCached>3</maxBuildsCached>
        </local>
        <!-- adjustMetaInf: makes the cache work correctly with Maven CI-friendly
             ${revision} placeholders (resolved by flatten-maven-plugin). -->
        <projectVersioning adjustMetaInf="true"/>
    </configuration>

</cache>
